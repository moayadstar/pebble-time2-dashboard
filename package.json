{
  "name": "pebble-time2-dashboard",
  "author": "OpenAI Codex",
  "version": "1.0.23",
  "keywords": [
    "pebble-watchface"
  ],
  "private": true,
  "scripts": {
    "version:patch": "node tools/version-guard.js --bump patch",
    "version:check": "node tools/version-guard.js --check",
    "prebuild": "node tools/version-guard.js --check"
  },
  "dependencies": {},
  "pebble": {
    "displayName": "Time2 Dashboard",
    "uuid": "9c9dfb1c-3071-4736-9102-0162ececb070",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "configurable": true,
    "capabilities": [
      "location"
    ],
    "targetPlatforms": [
      "basalt",
      "emery"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "SECOND_ZONE_OFFSET",
      "SECOND_ZONE_LABEL",
      "WEATHER_REQUEST",
      "WEATHER_TEMP",
      "WEATHER_COND",
      "WEATHER_CITY",
      "WEATHER_ERROR",
      "WEATHER_CODE",
      "LOCAL_ZONE_OFFSET",
      "LOCAL_ZONE_LABEL"
    ],
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "IMAGE_WEATHER_SUN",
          "file": "images/weather_sun.png"
        },
        {
          "type": "png",
          "name": "IMAGE_WEATHER_CLOUD",
          "file": "images/weather_cloud.png"
        },
        {
          "type": "png",
          "name": "IMAGE_WEATHER_RAIN",
          "file": "images/weather_rain.png"
        },
        {
          "type": "png",
          "name": "IMAGE_WEATHER_SNOW",
          "file": "images/weather_snow.png"
        },
        {
          "type": "png",
          "name": "IMAGE_WEATHER_STORM",
          "file": "images/weather_storm.png"
        }
      ]
    }
  }
}
